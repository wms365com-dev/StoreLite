# Copy this file to .env for each new store.
# Keep real secrets out of GitHub.

PORT=3000
NODE_ENV=production

# Admin
SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Store identity
STORE_NAME=New Store Name
STORE_TAGLINE=Curated online shop
STORE_DESCRIPTION=A focused storefront for a specific brand, niche, or client.
SUPPORT_EMAIL=support@example.com
LOGO_URL=
HERO_IMAGE_URL=
THEME_COLOR=#10243e
ACCENT_COLOR=#1f7a5c
CURRENCY=CAD

# Local defaults:
DATABASE_PATH=./data/store.db
UPLOADS_PATH=./uploads

# Railway volume defaults:
# DATABASE_PATH=/data/store.db
# UPLOADS_PATH=/data/uploads

# Stripe
STRIPE_SECRET_KEY=
SUCCESS_URL=https://your-domain.com/success
CANCEL_URL=https://your-domain.com/cart
